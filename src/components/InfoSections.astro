---
import SectionHeader from "@components/SectionHeader.astro";

const {
  intro,
  items = [],
  type = "cards",
  className = "",
  limit
} = Astro.props;

const list = (Array.isArray(items) ? items : items.items ?? [])
  .filter((item) => item.enabled !== false)
  .sort((a, b) => (a.order ?? 99) - (b.order ?? 99));
const visible = limit ? list.slice(0, limit) : list;
---

{intro?.enabled !== false && visible.length > 0 && (
  <section class={`section ${className}`}>
    <div class="container">
      <SectionHeader eyebrow={intro?.eyebrow} title={intro?.title} text={intro?.text} />
      {type === "timeline" ? (
        <div class="process-grid">
          {visible.map((item) => (
            <article>
              <span>{item.step || item.category || item.date}</span>
              <h3>{item.title}</h3>
              {item.text && <p>{item.text}</p>}
              {item.description && <p>{item.description}</p>}
            </article>
          ))}
        </div>
      ) : type === "downloads" ? (
        <div class="download-list">
          {visible.map((item) => (
            <article>
              <div>
                <span>{item.category}</span>
                <h3>{item.title}</h3>
                {item.description && <p>{item.description}</p>}
              </div>
              {(item.file || item.externalLink) && <a class="button button-light" href={item.file || item.externalLink}>Open</a>}
            </article>
          ))}
        </div>
      ) : (
        <div class="card-grid">
          {visible.map((item) => (
            <article class="info-card">
              {item.image && <img src={item.image} alt={item.alt ?? item.title} loading="lazy" />}
              <div>
                {(item.category || item.level || item.year) && <p class="meta">{[item.category, item.level, item.year].filter(Boolean).join(" · ")}</p>}
                <h3>{item.title || item.name}</h3>
                {item.result && <strong class="result-text">{item.result}</strong>}
                {item.description && <p>{item.description}</p>}
                {item.text && <p>{item.text}</p>}
                {(item.file || item.externalLink || item.document || item.certificate) && (
                  <a class="text-link" href={item.file || item.externalLink || item.document || item.certificate}>View details</a>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
)}
