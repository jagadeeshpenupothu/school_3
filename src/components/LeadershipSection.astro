---
import SectionHeader from "@components/SectionHeader.astro";
const { intro, staff } = Astro.props;
const leaders = (staff.leadership ?? [])
  .filter((item) => item.enabled !== false)
  .sort((a, b) => (a.order ?? 99) - (b.order ?? 99));
---

{intro?.enabled !== false && leaders.length > 0 && (
  <section class="section leadership-section">
    <div class="container">
      <SectionHeader eyebrow={intro.eyebrow} title={intro.title} text={intro.text} />
      <div class="leadership-grid">
        {leaders.map((leader) => (
          <article>
            {leader.photograph ? <img src={leader.photograph} alt={leader.alt ?? leader.name} loading="lazy" /> : <div class="leader-initial" aria-hidden="true">{leader.role?.slice(0, 1)}</div>}
            <div>
              <p class="meta">{leader.role}</p>
              <h3>{leader.name}</h3>
              {leader.shortMessage && <blockquote>{leader.shortMessage}</blockquote>}
              {leader.signature && <p>{leader.signature}</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
