{
  "page": {
    "title": "Contact",
    "description": "Contact Sri Vidya Vardhini School for admission enquiry, school office, transport information, directions, and parent support."
  },
  "hero": {
    "enabled": true,
    "eyebrow": "Contact",
    "title": "Admission enquiry, office contact and directions.",
    "text": "Parents can contact the school office, request admission guidance, ask about transport, or plan a campus visit."
  },
  "contact": {
    "enabled": true,
    "officeTitle": "School Office",
    "showAddress": true,
    "showEmail": true,
    "showPhone": true,
    "showHours": true
  },
  "form": {
    "enabled": true,
    "action": "/",
    "method": "post",
    "submitLabel": "Submit Enquiry",
    "fields": [
      { "enabled": true, "label": "Parent / Guardian Name", "name": "parent-name", "type": "text", "autocomplete": "name", "required": true },
      { "enabled": true, "label": "Student Name", "name": "student-name", "type": "text", "autocomplete": "off", "required": true },
      { "enabled": true, "label": "Mobile Number", "name": "mobile", "type": "tel", "autocomplete": "tel", "required": true },
      { "enabled": true, "label": "Email", "name": "email", "type": "email", "autocomplete": "email", "required": false },
      {
        "enabled": true,
        "label": "Class Seeking Admission",
        "name": "class",
        "type": "select",
        "options": ["Nursery", "LKG", "UKG", "Class I", "Class II", "Class III", "Class IV", "Class V", "Class VI", "Class VII", "Class VIII", "Class IX", "Class X", "Class XI", "Class XII"],
        "required": true
      },
      {
        "enabled": true,
        "label": "Academic Year",
        "name": "academic-year",
        "type": "select",
        "options": ["2026-27", "2027-28"],
        "required": true
      },
      { "enabled": true, "label": "Message", "name": "message", "type": "textarea", "rows": 5, "required": false },
      { "enabled": true, "label": "I agree to be contacted by the school admission office.", "name": "consent", "type": "checkbox", "required": true }
    ]
  }
}
